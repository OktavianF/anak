# Connect to Supabase via connection pooling (for runtime queries)
DATABASE_URL="postgresql://postgres.krnfuwmlzabyvmludvvq:[YOUR-PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database (for migrations)
DIRECT_URL="postgresql://postgres.krnfuwmlzabyvmludvvq:[YOUR-PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"

# Server
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-long
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=debug
